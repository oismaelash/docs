  "keyFeatures": [
    "Send and receive WhatsApp messages via REST API",
    "Official Meta integration via Cloud API and Coexistence",
    "Unofficial (non-official) API with managed proxy included",
    "Webhooks delivering events in milliseconds (sent, delivered, read)",
    "Multi-number and multi-tenant support per project",
    "Live chat dashboard to respond to conversations in real time",
    "Full message logs with auditable history",
    "Real-time analytics (send, delivery, read metrics)",
    "API Layer for zero-code migration from Evolution API providers",
    "MCP server and SDKs for AI agent integrations",
    "Interactive messages with buttons and media support",
    "Template management with variable substitution"
  ],
